{
  "log":{},
  "dns":{},
  "stats":{},
  "inbounds":[
    {
      "settings":{
        "auth":"noauth",
        "udp":true
      },
      "protocol":"socks",
      "port":"$socks_port",
      "tag":"in-0"
    },
    {
      "settings":{},
      "protocol":"http",
      "port":"$http_port",
      "tag":"in-1"
    }
  ],
  "outbounds":[
    {
      "settings":{
        "vnext":[
          {
            "address":"$domain",
            "port":443,
            "users":[
              {
                "alterId":32,
                "id":"$user_uuid"
              }
            ]
          }
        ]
      },
      "protocol":"vmess",
      "streamSettings":{
        "security":"tls",
        "tlsSettings":{
          "serverName":"$domain"
        },
        "wsSettings":{
          "path":"/$path_uuid"
        },
        "network":"ws"
      },
      "tag":"out-0"
    },
    {
      "tag":"direct",
      "protocol":"freedom",
      "settings":{}
    },
    {
      "tag":"blocked",
      "protocol":"blackhole",
      "settings":{}
    }
  ],
  "routing":{
    "domainStrategy":"IPOnDemand",
    "rules":[
      {
        "outboundTag":"direct",
        "ip":[
          "geoip:private"
        ],
        "type":"field"
      },
      {
        "outboundTag":"direct",
        "inboundTag":[
          "in-0",
          "in-1"
        ],
        "ip":[
          "geoip:cn"
        ],
        "type":"field"
      }
    ]
  },
  "policy":{},
  "reverse":{},
  "transport":{}
}