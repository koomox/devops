{
	"log": {
		"access": "",
		"error": "",
		"logerror": "warning"
	},
	"inbound": {
		"port": 11000,
		"listen": "0.0.0.0",
		"protocol": "shadowsocks",
		"streamSettings": {
			"network": "kcp",
			"security": "none",
			"kcpSettings": {
				"mtu": 1350,
				"tti": 20,
				"uplinkCapacity": 5,
				"downlinkCapacity": 20,
				"congestion": true,
				"readBufferSize": 1,
				"writeBufferSize": 1,
				"header": {
					"type": "none"
				}
			}
		},
		"settings": {
			"method": "aes-256-cfb",
			"password": "${password}",
			"udp": false,
			"level": 0,
			"ota": true
		},
	},
	"outbound": {
		"protocol": "freedom",
		"settings": {}
	}
}